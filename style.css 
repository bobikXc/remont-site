/* Простые современные шрифты */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    line-height: 1.6;
    color: #333;
}

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
}

/* Шапка */
.header {
    background: #1a1a1a; /* Темный, почти черный */
    padding: 20px 0;
    position: sticky;
    top: 0;
    z-index: 100;
}
.header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.logo {
    color: #d4af37; /* Золотой */
    text-decoration: none;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 1px;
}
.phone {
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 18px;
}

/* Главный экран */
.hero {
    background: #2c2c2c;
    color: #fff;
    padding: 100px 0;
    text-align: left;
}
.hero h1 {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 20px;
    max-width: 600px;
    line-height: 1.2;
}
.hero p {
    font-size: 18px;
    color: #ccc;
    margin-bottom: 40px;
    max-width: 500px;
}
.btn {
    display: inline-block;
    background: #d4af37;
    color: #1a1a1a;
    padding: 15px 40px;
    text-decoration: none;
    font-weight: 700;
    border-radius: 5px;
    transition: 0.3s;
}
.btn:hover {
    background: #b8962e;
}

/* Услуги */
.services {
    padding: 80px 0;
}
.services h2 {
    text-align: center;
    font-size: 36px;
    margin-bottom: 50px;
    color: #1a1a1a;
}
.cards {
    display: flex;
    gap: 30px;
    justify-content: center;
    flex-wrap: wrap; /* Чтобы на телефоне колонки встали друг под друга */
}
.card {
    background: #f8f8f8;
    padding: 40px 25px;
    border-radius: 8px;
    flex: 1;
    min-width: 250px;
    border-bottom: 4px solid #d4af37;
}
.icon {
    font-size: 40px;
    margin-bottom: 15px;
}
.card h3 {
    margin-bottom: 10px;
    font-size: 20px;
}

/* Подвал */
.footer {
    background: #1a1a1a;
    color: #777;
    text-align: center;
    padding: 30px 0;
    font-size: 14px;
}
/* === ПОРТФОЛИО === */
.portfolio {
    padding: 80px 0;
    background: #fff; /* Белый фон, чтобы разбавить черный */
}
.subtitle {
    text-align: center;
    color: #777;
    margin-bottom: 50px;
    margin-top: -30px;
    font-size: 18px;
}
.gallery {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
    justify-content: center;
}
.gallery-item {
    flex: 1;
    min-width: 300px;
    max-width: 500px;
    text-align: center;
}
/* Контейнеры для фото "До/После" */
.image-box {
    position: relative;
    margin-bottom: 10px;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}
.image-box img {
    width: 100%;
    display: block;
    transition: transform 0.3s;
}
.image-box:hover img {
    transform: scale(1.05);
}
.badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: rgba(0,0,0,0.7);
    color: #fff;
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
}
.badge.after {
    left: auto;
    right: 15px;
    background: #d4af37;
    color: #1a1a1a;
}
.gallery-item h3 {
    margin-top: 15px;
    font-size: 20px;
}
.gallery-item p {
    color: #666;
    font-size: 14px;
    margin-top: 5px;
}

/* === ПОРТФОЛИО СЛАЙДЕР === */
.portfolio {
    padding: 80px 0;
    background: #fff;
}
.subtitle {
    text-align: center;
    color: #777;
    margin-bottom: 50px;
    margin-top: -30px;
    font-size: 18px;
}
.slider-wrapper {
    display: flex;
    flex-direction: column;
    gap: 60px;
    max-width: 900px;
    margin: 0 auto;
}
.project-title {
    text-align: center;
    font-size: 22px;
    margin-bottom: 15px;
    color: #1a1a1a;
}
.project-meta {
    text-align: center;
    color: #888;
    font-size: 14px;
    margin-top: 10px;
}

/* Контейнер слайдера сравнения */
.img-comp-container {
    position: relative;
    width: 100%;
    height: 400px; /* Фиксированная высота */
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    cursor: col-resize;
}
.img-comp-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
}
.img-comp-img img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Чтобы картинка заполняла блок красиво */
    display: block;
}
.img-comp-overlay {
    width: 50%; /* Изначально показываем половину "До" */
    border-right: 3px solid #d4af37;
}

/* Сам ползунок (бегунок) */
.img-comp-slider {
    position: absolute;
    z-index: 9;
    cursor: col-resize;
    width: 40px;
    height: 40px;
    background-color: #d4af37;
    border: 3px solid #fff;
    border-radius: 50%;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 10px rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
}
.img-comp-slider::before,
.img-comp-slider::after {
    content: '';
    position: absolute;
    width: 2px;
    height: 20px;
    background: #fff;
}
.img-comp-slider::before {
    left: 8px;
}
.img-comp-slider::after {
    right: 8px;
}

/* === КАРТА === */
.map-section {
    padding-top: 80px;
    background: #f8f8f8;
    text-align: center;
}
.map-container {
    margin-top: 30px;
    filter: grayscale(30%); /* Сделаем карту стильной */
}
/* === COOKIE CONSENT === */
.cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #1a1a1a;
    border-top: 2px solid #d4af37;
    padding: 20px 0;
    z-index: 9999;
    animation: slideUp 0.5s ease;
}
@keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
}
.cookie-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
}
.cookie-content p {
    color: #aaa;
    font-size: 14px;
    margin: 0;
    flex: 1;
}
.cookie-content a {
    color: #d4af37;
    text-decoration: underline;
}
.cookie-btn {
    white-space: nowrap;
    padding: 10px 30px;
}